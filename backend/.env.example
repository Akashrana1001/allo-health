# Postgres (Neon) — pooled connection string used at runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connection_limit=1"

# Postgres (Neon) — direct connection string used by Prisma migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/dbname?sslmode=require"

# Upstash Redis — used for idempotency cache
UPSTASH_REDIS_REST_URL="https://your-upstash-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Random string used to authorise calls to the cron endpoint
CRON_SECRET="generate-a-strong-random-string"

# CORS origin for the frontend (e.g. http://localhost:3000 for local dev)
FRONTEND_ORIGIN="http://localhost:3000"

# Server port
PORT=4000

# Default reservation hold window in minutes
RESERVATION_TTL_MINUTES=10
